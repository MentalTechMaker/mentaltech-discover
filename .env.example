# Configuration de l'application MentalTech Discover
# Copier ce fichier en .env pour la configuration locale

# Mode de l'application
NODE_ENV=production

# Port de l'application (utilisé uniquement en mode dev sans Docker)
# En production Docker, le port est défini dans docker-compose.yml
PORT=5173

# URL de base de l'application (pour la production)
# VITE_APP_URL=https://votredomaine.com

# Note: Aucune clé API ou secret ne doit être ajouté ici
# Cette application est 100% frontend et ne nécessite pas de secrets
