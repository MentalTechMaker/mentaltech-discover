# Configuration MentalTech Discover - Monorepo
# Copier ce fichier en .env pour la configuration locale

# PostgreSQL
POSTGRES_DB=mentaltech
POSTGRES_USER=mentaltech
POSTGRES_PASSWORD=mentaltech_secret

# Backend
DATABASE_URL=postgresql://mentaltech:mentaltech_secret@db:5432/mentaltech
SECRET_KEY=change-me-in-production-use-a-long-random-string
CORS_ORIGINS=http://localhost:3033,http://localhost:5173

# Frontend
NODE_ENV=production
